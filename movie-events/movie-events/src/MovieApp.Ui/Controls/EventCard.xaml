<UserControl
    x:Class="MovieApp.Ui.Controls.EventCard"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <UserControl.Resources>
        <SolidColorBrush x:Key="StatusPendingBrush" Color="#1A808080" />
        <SolidColorBrush x:Key="StatusEndedBrush" Color="#22949494" />
        <SolidColorBrush x:Key="StatusSoldOutBrush" Color="#33D13438" />
        <SolidColorBrush x:Key="StatusAvailableBrush" Color="#3316A34A" />
    </UserControl.Resources>

    <Border
        Width="284"
        Padding="0"
        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
        BorderThickness="1"
        CornerRadius="8">
        <Grid RowSpacing="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="156" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Border
                Grid.Row="0"
                Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}"
                CornerRadius="8,8,0,0">
                <Grid>
                    <StackPanel 
                        Orientation="Horizontal" 
                        HorizontalAlignment="Right" 
                        VerticalAlignment="Top" 
                        Margin="8" 
                        Spacing="8">

                        <ToggleButton
                            x:Name="WatcherButton"
                            Width="36"
                            Height="36"
                            Padding="0"
                            Background="{ThemeResource ControlFillColorDefaultBrush}"
                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                            BorderThickness="1"
                            Click="WatcherButton_Click"
                            CornerRadius="18"
                            ToolTipService.ToolTip="Set price alert">
                            <FontIcon
                                FontSize="16"
                                Glyph="&#xEA8F;" />
                        </ToggleButton>

                        <ToggleButton
                            x:Name="FavoriteButton"
                            Width="36"
                            Height="36"
                            Padding="0"
                            Background="{ThemeResource ControlFillColorDefaultBrush}"
                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                            BorderThickness="1"
                            Click="FavoriteButton_Click"
                            IsChecked="{x:Bind IsFavorited, Mode=OneWay}"
                            CornerRadius="18"
                            ToolTipService.ToolTip="Add to favorites">
                            <FontIcon
                                FontSize="16"
                                Glyph="{x:Bind FavoriteIconGlyph, Mode=OneWay}"
                                Foreground="{x:Bind FavoriteIconForeground, Mode=OneWay}" />
                        </ToggleButton>
                    </StackPanel>

                    <Grid Padding="16">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="6">
                            <Border
                                HorizontalAlignment="Left"
                                Padding="10,4"
                                Background="{ThemeResource ControlFillColorSecondaryBrush}"
                                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                BorderThickness="1"
                                CornerRadius="6">
                                <TextBlock
                                    FontSize="12"
                                    FontWeight="SemiBold"
                                    Text="{x:Bind EventTypeText, Mode=OneTime}" />
                            </Border>

                            <Border
                                Padding="10,4"
                                Background="#33FFD700"
                                BorderBrush="#FFD4A017"
                                BorderThickness="1"
                                CornerRadius="6"
                                Visibility="{x:Bind DiscountBadgeVisibility, Mode=OneWay}">
                                <StackPanel Orientation="Horizontal" Spacing="4">
                                    <FontIcon Glyph="&#xE7FC;" FontSize="12" Foreground="#FFD4A017" />
                                    <TextBlock
                                        FontSize="12"
                                        FontWeight="SemiBold"
                                        Foreground="#FFD4A017"
                                        Text="{x:Bind DiscountBadgeText, Mode=OneWay}" />
                                </StackPanel>
                            </Border>
                        </StackPanel>

                        <TextBlock
                            Grid.Row="2"
                            FontSize="28"
                            FontWeight="SemiBold"
                            Text="{x:Bind DateBadgeDay, Mode=OneTime}" />
                    </Grid>
                </Grid>
            </Border>

            <StackPanel
                Grid.Row="1"
                Padding="16"
                Spacing="12">
                <StackPanel Spacing="8">
                    <TextBlock
                        Style="{ThemeResource SubtitleTextBlockStyle}"
                        Text="{x:Bind TitleText, Mode=OneTime}"
                        TextTrimming="CharacterEllipsis"
                        TextWrapping="WrapWholeWords" />

                    <TextBlock
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                        MaxLines="2"
                        Text="{x:Bind DescriptionText, Mode=OneTime}"
                        TextTrimming="CharacterEllipsis"
                        TextWrapping="WrapWholeWords" />
                </StackPanel>

                <Grid ColumnSpacing="12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Spacing="6">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <FontIcon Glyph="&#xE787;" />
                            <TextBlock
                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                Text="{x:Bind ScheduleText, Mode=OneTime}"
                                TextWrapping="WrapWholeWords" />
                        </StackPanel>

                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <FontIcon Glyph="&#xE707;" />
                            <TextBlock
                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                Text="{x:Bind LocationText, Mode=OneTime}"
                                TextTrimming="CharacterEllipsis" />
                        </StackPanel>
                    </StackPanel>

                    <Border
                        Grid.Column="1"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Top"
                        Padding="10,6"
                        Background="{x:Bind StatusBackgroundBrush, Mode=OneWay}"
                        CornerRadius="999">
                        <TextBlock
                            FontSize="12"
                            FontWeight="SemiBold"
                            Text="{x:Bind StatusText, Mode=OneWay}" />
                    </Border>
                </Grid>

                <Grid ColumnSpacing="12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Spacing="2">
                        <TextBlock
                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                            Style="{ThemeResource CaptionTextBlockStyle}"
                            Text="Price" />
                        <TextBlock
                            FontWeight="SemiBold"
                            Text="{x:Bind PriceText, Mode=OneWay}" />
                    </StackPanel>

                    <StackPanel
                        Grid.Column="1"
                        Spacing="2">
                        <TextBlock
                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                            Style="{ThemeResource CaptionTextBlockStyle}"
                            Text="Rating" />
                        <TextBlock
                            FontWeight="SemiBold"
                            Text="{x:Bind RatingText, Mode=OneTime}" />
                    </StackPanel>

                    <StackPanel
                        Grid.Column="2"
                        Spacing="2">
                        <TextBlock
                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                            Style="{ThemeResource CaptionTextBlockStyle}"
                            Text="Capacity" />
                        <TextBlock
                            FontWeight="SemiBold"
                            Text="{x:Bind CapacityText, Mode=OneTime}" />
                    </StackPanel>
                </Grid>

                <Grid Margin="0,15,0,0">
                    <Button
                        x:Name="JoinButton"
                        HorizontalAlignment="Stretch"
                        Content="Join Event"
                        Tag="Join Event"
                        Visibility="{x:Bind JoinButtonVisibility, Mode=OneWay}"
                        Click="JoinEventButton_Click" />

                    <TextBlock
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        FontWeight="SemiBold"
                        Opacity="0.7"
                        Text="Already joined"
                        Visibility="{x:Bind JoinedStatusVisibility, Mode=OneWay}" />
                </Grid>
            </StackPanel>
        </Grid>
    </Border>
</UserControl>